{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "next build",
  "regions": ["dub1"],
  "functions": {
    "src/app/api/cron/ingest-news/route.ts": {
      "maxDuration": 60,
      "memory": 1024
    },
    "src/app/api/cron/tick/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/cron/refresh-klines-daily/route.ts": {
      "maxDuration": 120,
      "memory": 1024
    },
    "src/app/api/cron/generate-briefing/route.ts": {
      "maxDuration": 60,
      "memory": 1024
    },
    "src/app/api/data/**/route.ts": {
      "maxDuration": 15
    },
    "src/app/api/agent/**/route.ts": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "crons": [
    {
      "path": "/api/cron/ingest-news",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/refresh-klines-daily",
      "schedule": "30 2 * * *"
    }
  ]
}
