# =============================================================================
# SosoAlpha — Environment Configuration
# =============================================================================
# Copy this file to .env.local and fill in your real values.
# .env.local is gitignored and stays on your machine only.
# =============================================================================

# -----------------------------------------------------------------------------
# SoSoValue OpenAPI
# Get your key: https://sosovalue.com/developer/dashboard
# Docs: https://sosovalue-1.gitbook.io/sosovalue-api-doc
# -----------------------------------------------------------------------------
SOSOVALUE_API_KEY=
SOSOVALUE_BASE_URL=https://openapi.sosovalue.com/openapi/v1
# Rate limit for SoSoValue OpenAPI. Free tier is 20 req/min — bump if you
# upgrade. Lower it if you're getting persistent 429s.
SOSOVALUE_RATE_LIMIT_PER_MIN=20

# -----------------------------------------------------------------------------
# SoDEX (mainnet only — testnet doesn't exist)
# Read-only market data for now. We never auto-trade.
# Docs: https://sodex.com/documentation/api/api
# -----------------------------------------------------------------------------
# SoDEX uses EVM-address API keys + EIP-712 signatures for write endpoints.
# Public market data endpoints do NOT require auth, so for paper trading
# (read-only) you can leave the key/secret blank.
SODEX_API_KEY=
SODEX_API_SECRET=
SODEX_SPOT_REST_URL=https://mainnet-gw.sodex.dev/api/v1/spot
SODEX_PERPS_REST_URL=https://mainnet-gw.sodex.dev/api/v1/perps
SODEX_SPOT_WS_URL=wss://mainnet-gw.sodex.dev/ws/spot
SODEX_PERPS_WS_URL=wss://mainnet-gw.sodex.dev/ws/perps

# -----------------------------------------------------------------------------
# Anthropic — Claude AI for event classification & pattern discovery
# Get your key: https://console.anthropic.com/settings/keys
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# -----------------------------------------------------------------------------
# Database (SQLite local file)
# -----------------------------------------------------------------------------
DATABASE_PATH=./data/sosoalpha.db

# -----------------------------------------------------------------------------
# App config
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME=SosoAlpha
NEXT_PUBLIC_APP_TAGLINE=Event-Driven Alpha for On-Chain Finance
